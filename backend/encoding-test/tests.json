{
  "tests": [
    {
      "name": "No token returns 403",
      "method": "GET",
      "path": "/?text=hello",
      "expectedStatus": 403,
      "expectedBody": {"error": "Forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing params returns 400",
      "method": "GET",
      "path": "/",
      "headers": {"X-Admin-Token": "${ADMIN_TOKEN}"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Укажите параметр text= или hex="},
      "bodyMatcher": "partial"
    },
    {
      "name": "Text mode",
      "method": "GET",
      "path": "/?text=hello",
      "headers": {"X-Admin-Token": "${ADMIN_TOKEN}"},
      "expectedStatus": 200,
      "expectedBody": {"mode": "text", "length": 5, "octet_length": 5},
      "bodyMatcher": "partial"
    }
  ]
}
